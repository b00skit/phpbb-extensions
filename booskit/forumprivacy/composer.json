{
	"name": "booskit/forumprivacy",
	"type": "phpbb-extension",
	"description": "Adds privacy controls to forums, allowing users to only see/post/search their own topics.",
	"homepage": "https://github.com/booskit/phpbb-extensions",
	"version": "1.0.0",
	"license": "MIT",
	"authors": [
		{
			"name": "Booskit",
			"homepage": "https://github.com/booskit"
		}
	],
	"require": {
		"php": ">=7.1.3",
		"composer/installers": "~1.0"
	},
	"extra": {
		"display-name": "Forum Privacy",
		"soft-require": {
			"phpbb/phpbb": ">=3.3.0"
		}
	}
}
